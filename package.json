{
  "name": "claude-pets",
  "version": "0.1.4",
  "description": "Desktop pet + universal agent CLI shell — drag a transparent pet onto your screen, chat with Claude / Codex / opencode through a single interface.",
  "main": "out/main/index.js",
  "author": {
    "name": "wsxwj123",
    "email": "wsxwj123@users.noreply.github.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/wsxwj123/claude-pet",
  "repository": {
    "type": "git",
    "url": "https://github.com/wsxwj123/claude-pet.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "package": "electron-vite build && electron-builder --mac --publish never",
    "package:mac": "electron-vite build && electron-builder --mac --publish never",
    "package:linux": "electron-vite build && electron-builder --linux --publish never",
    "package:win": "electron-vite build && electron-builder --win --publish never",
    "package:all": "electron-vite build && electron-builder -mwl --publish never"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.47",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.wsxwj.claudepets",
    "productName": "claude-pets",
    "copyright": "Copyright © 2026 wsxwj123",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "assets/**/*",
      "bin/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": ["**/*"]
      },
      {
        "from": "assets/pets",
        "to": "assets/pets",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "title": "claude-pets ${version}"
    },
    "linux": {
      "category": "Utility",
      "icon": "build/icon.png",
      "target": [
        { "target": "AppImage", "arch": ["x64", "arm64"] },
        { "target": "deb", "arch": ["x64", "arm64"] }
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    }
  }
}
